# ─── Copy to .env and fill in. Never commit real secrets. ───

# --- Database ---
DATABASE_URL=postgresql+psycopg://coach:coach@localhost:5432/lifecoach
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://coach:coach@localhost:5432/lifecoach

# --- Redis (cache, rate limit, Celery broker/result) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=

# --- LLM providers (via LiteLLM) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model routing (overridable per task)
COACH_MODEL=anthropic/claude-sonnet-4-6
EXTRACTION_MODEL=anthropic/claude-haiku-4-5-20251001
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Web client ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
