# ─── Copy to .env and fill in. Never commit real secrets. ───

# --- Database ---
DATABASE_URL=postgresql+psycopg://coach:coach@localhost:5432/lifecoach
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://coach:coach@localhost:5432/lifecoach

# --- Redis (cache, rate limit, Celery broker/result) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth (Clerk) ---
# OAuth providers (free tier): Email, Apple, Google, X/Twitter
# Find in Clerk Dashboard → API Keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=   # https://<slug>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER is optional — Clerk does not display it in the dashboard.
# Leave blank to skip issuer validation (signature + expiry still checked).
CLERK_ISSUER=

# --- LLM provider (via LiteLLM) ---
# Phase 1: Using Anthropic only (simplest, most reliable for MVP)
ANTHROPIC_API_KEY=

# Model routing (all Anthropic for Phase 1)
COACH_MODEL=anthropic/claude-sonnet-4-6
EXTRACTION_MODEL=anthropic/claude-haiku-4-5-20251001
EMBEDDING_MODEL=anthropic/claude-3-5-haiku-20241022

# --- Observability (Langfuse — self-hosted via docker-compose.langfuse.yml) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Web client ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
